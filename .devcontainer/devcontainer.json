{
  "name": "python-ai-assisted-dev-sample",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -e .[dev]",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs",
        "mhutchie.git-graph",
        "github.vscode-github-actions",
        "GitHub.copilot-chat",
        "DavidAnson.vscode-markdownlint"
      ]
    }
  }
}
